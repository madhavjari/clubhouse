<!DOCTYPE html>
<html lang="en">
  <%- include("./partials/head.ejs") %>
  <body class="page dashboard-page">
    <header class="site-header dashboard-header">
      <a class="brand" href="/">
        <span class="brand-mark">M</span>
        <span>Madhav's Club</span>
      </a>
      <nav class="nav-actions" aria-label="Dashboard actions">
        <% if (status === 'None'){ %>
          <a class="button button-soft" href="/joinclub">Join the club</a>
        <% } %>
        <a class="button button-ghost" href="/log-out">Log out</a>
      </nav>
    </header>

    <main class="dashboard-shell">
      <section class="welcome-panel">
        <div>
          <p class="eyebrow">Member dashboard</p>
          <h1>Hello, <%= user.firstname + " " + user.lastname %></h1>
          <p>
            Keep the club board fresh with a note, update, question, or tiny
            victory worth sharing.
          </p>
        </div>
        <button class="button button-primary message" type="button">
          Create a message
        </button>
      </section>

      <section class="dashboard-grid" aria-label="Club status">
        <article class="stat-card">
          <span class="stat-label">Membership</span>
          <strong><%= status %></strong>
          <p>Your current club access level.</p>
        </article>
        <article class="stat-card">
          <span class="stat-label">Username</span>
          <strong><%= user.username %></strong>
          <p>Your public name on the board.</p>
        </article>
        <article class="stat-card stat-card-accent">
          <span class="stat-label">Club notes</span>
          <strong><%= messages.length %></strong>
          <p><%= messages.length === 1 ? "Message" : "Messages" %> on the board.</p>
        </article>
      </section>

      <section class="feed-panel" aria-label="Members messages">
        <div class="feed-heading">
          <div>
            <p class="eyebrow">Members messages</p>
            <h2>Club board</h2>
          </div>
          <% if (status === 'Admin') { %>
            <span class="role-pill">Admin tools enabled</span>
          <% } else if (status === 'Member') { %>
            <span class="role-pill">Member view</span>
          <% } else { %>
            <span class="role-pill">Preview view</span>
          <% } %>
        </div>

        <% if(messages.length === 0){ %>
          <div class="empty-state board-empty">
            <span class="empty-icon">+</span>
            <h3>No messages yet</h3>
            <p>Create the first note for the clubhouse.</p>
          </div>
        <% } else { %>
          <div class="feed-list">
            <% messages.forEach((message) =>{ %>
              <article class="message-card message-card-full">
                <% if(status === 'Member' || status === 'Admin') { %>
                  <div class="avatar"><%= message.firstname.charAt(0).toUpperCase() %></div>
                <% } else { %>
                  <div class="avatar anonymous-avatar">#</div>
                <% } %>
                <div class="message-content">
                  <% if(status === 'Member' || status === 'Admin') { %>
                    <div class="message-meta">
                      <strong><%= message.firstname + " " + message.lastname %></strong>
                      <span><%= message.timestamp ? String(message.timestamp).slice(0, 10) : "" %></span>
                    </div>
                  <% } %>
                  <p class="message-body"><%= message.message %></p>
                </div>
                <% if (status === 'Admin') { %>
                  <button
                    class="icon-button delete-button"
                    type="button"
                    aria-label="Delete message"
                    data-dialog="delete-<%= message.message_id %>"
                  >
                    x
                  </button>
                  <dialog class="delete-modal" id="delete-<%= message.message_id %>">
                    <form
                      class="modal-card delete-card"
                      action="/delete/<%= message.message_id %>"
                      method="post"
                    >
                      <div class="modal-heading">
                        <p class="eyebrow">Confirm delete</p>
                        <h2>Delete this message?</h2>
                      </div>
                      <p class="message-body">
                        This removes the note from the club board.
                      </p>
                      <div class="modal-actions">
                        <button
                          class="button button-ghost delete-close-modal"
                          type="button"
                        >
                          Cancel
                        </button>
                        <button class="button button-danger" type="submit">
                          Delete
                        </button>
                      </div>
                    </form>
                  </dialog>
                <% } %>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>
    </main>


    <dialog class="modal">
      <form
        class="form-stack modal-card"
        action="/messages"
        method="POST"
      >
        <div class="modal-heading">
          <p class="eyebrow">New message</p>
          <h2>Create a message</h2>
        </div>
        <div class="field">
          <label for="title">Title</label>
          <input
            id="title"
            name="title"
            type="text"
            required
            minlength="2"
            maxlength="100"
          />
        </div>
        <div class="field">
          <label for="message">Message</label>
          <textarea
            id="message"
            name="message"
            required
            maxlength="1000"
            rows="6"
          ></textarea>
        </div>
        <div class="modal-actions">
          <button class="button button-ghost close-modal" type="button">
            Cancel
          </button>
          <button class="button button-primary" type="submit">Save</button>
        </div>
      </form>
    </dialog>
  </body>
  <script>
    const messageForm = document.querySelector(".modal");
    const messageButton = document.querySelector(".message");
    const closeButton = document.querySelector(".close-modal");
    const deleteButtons = document.querySelectorAll(".delete-button");
    const deleteCloseButtons = document.querySelectorAll(".delete-close-modal");

    deleteButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const dialog = document.getElementById(button.dataset.dialog);
        dialog.showModal();
      });
    });

    deleteCloseButtons.forEach((button) => {
      button.addEventListener("click", () => {
        button.closest("dialog").close();
      });
    });

    messageButton.addEventListener("click", (event) => {
      messageForm.showModal();
    });

    closeButton.addEventListener("click", () => {
      messageForm.close();
    });
  </script>
</html>
